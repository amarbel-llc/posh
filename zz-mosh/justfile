# zz-mosh justfile — host-lane recipes for the C++ mosh reference tree.
# The hermetic lane lives in the root justfile (build-nix/test-nix realize
# the root flake's .#mosh, sourced from this subtree); these recipes build
# and test in-tree via the root flake's devShell. Invoke from the repo
# root as `just zz-mosh/<recipe>` or via the root's thin delegations.
# See eng-design_patterns-justfile(7).

default: build test

# --- build -------------------------------------------------------------

build: build-autotools

# Fast C++ dev-loop: autotools build in the devShell, no nix rebuild.
[group("build")]
build-autotools:
    # Leaves build products in this tree for iteration.
    nix develop ../. --command bash -c './autogen.sh && ./configure --with-crypto-library=openssl && make'

# --- post-build --------------------------------------------------------

test: test-autotools

# Full host `make check` (includes the tmux emulation tests).
[group("post-build")]
test-autotools: build-autotools
    # The nix sandbox SKIPs the tmux/pty emulation tests; this runs them
    # on the host. Known host failure on macOS: emulation-80th-column
    # (github #2).
    nix develop ../. --command make check

# --- maintenance -------------------------------------------------------

[group("maintenance")]
clean-build:
    nix develop ../. --command bash -c 'make distclean || true'

# --- debug -------------------------------------------------------------

# Run a single autotools test by name in the devShell (fast iteration).
[group("debug")]
debug-test-one name: build-autotools
    # e.g. `just zz-mosh/debug-test-one mouse-alternate-scroll.test` — runs
    # one test via `make check TESTS=<name>` without the whole suite.
    nix develop ../. --command make -C src/tests check TESTS='{{ name }}'

# Build the current branch's C++ tree natively on a remote Linux host.
[group("debug")]
debug-build-remote host:
    #!/usr/bin/env bash
    set -euo pipefail
    # Push the current branch, then clone-if-absent / fetch / checkout /
    # build via the flake devShell on the remote. -A forwards the ssh agent
    # for the remote's git clone; `bash -l` is a login shell so nix + git
    # are on PATH. Leaves the build at ~/eng/repos/posh/zz-mosh/src/frontend/.
    host='{{ host }}'
    jd='{{ justfile_directory() }}'
    branch=$(git -C "$jd" rev-parse --abbrev-ref HEAD)
    git -C "$jd" push -u origin "$branch"
    # shellcheck disable=SC2087
    ssh -A "$host" bash -l -s <<EOF
    set -euo pipefail
    if [ ! -d ~/eng/repos/posh/.git ]; then
      mkdir -p ~/eng/repos && git clone git@github.com:amarbel-llc/posh.git ~/eng/repos/posh
    fi
    cd ~/eng/repos/posh
    git fetch origin
    git checkout $branch
    git reset --hard origin/$branch
    nix develop --command bash -c 'cd zz-mosh && ./autogen.sh && ./configure --with-crypto-library=openssl && make -j'
    echo "remote build OK: \$(pwd)/zz-mosh/src/frontend/mosh-server"
    EOF

# Open mosh against the remote-built server (run debug-build-remote first).
[group("debug")]
debug-mosh-remote host *ARGS: build-autotools
    #!/usr/bin/env bash
    set -euo pipefail
    # Builds the local client, runs it against the remote-built mosh-server.
    # ARGS are passed verbatim to mosh after the host: append a remote
    # command (e.g. `-- less --mouse f`), or pass nothing for a login shell.
    # Run from a real terminal (kitty). For a logging build, build a branch
    # with instrumentation on the remote first.
    host='{{ host }}'
    jd='{{ justfile_directory() }}'
    mosh --client="$jd/src/frontend/mosh-client" \
         --server='~/eng/repos/posh/zz-mosh/src/frontend/mosh-server' \
         "$host" {{ ARGS }} || true
